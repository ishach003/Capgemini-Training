<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="B1" class="di.Book">
        <property name="bookId" value="1"/>
        <property name="bookName" value="Lord of rings"/>
    </bean>
    <bean id="L1" class="di.Library">
        <property name="id" value="101"/>
        <property name="name" value="mystery"/>
        <property name="book" ref="B1"/>
    </bean>
    <!--    <bean id="bean" class="IOCwithXml.Koala"/>-->
</beans>